#!/bin/sh

msg_file="$1"
msg="$(cat "$msg_file")"

first_line="$(printf '%s\n' "$msg" | sed -n '1p')"
second_line="$(printf '%s\n' "$msg" | sed -n '2p')"
rest_lines="$(printf '%s\n' "$msg" | sed -n '3,$p')"

header_pattern='^(build|feat|fix|refactor|test|docs|chore): .+'

if ! printf '%s\n' "$first_line" | grep -Eq "$header_pattern"; then
  echo "Invalid commit message header."
  echo "Expected: type: subject"
  echo "Allowed types: build|feat|fix|refactor|test|docs|chore"
  echo "Example: build: upgrade exception starter to 2.0.1"
  exit 1
fi

if [ -n "$second_line" ]; then
  echo "Second line must be blank."
  exit 1
fi

if [ -n "$rest_lines" ] && ! printf '%s\n' "$rest_lines" | grep -Eq '^  [0-9]+\. .+'; then
  echo "Body lines must use the format: '  1. summary'"
  exit 1
fi
